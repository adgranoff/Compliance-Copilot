# GitHub Configuration
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Mock Service URLs (for development)
WORK_IQ_URL=http://localhost:3001
FABRIC_IQ_URL=http://localhost:3002

# Azure Configuration (production)
# AZURE_TENANT_ID=your_tenant_id
# AZURE_CLIENT_ID=your_client_id
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net
# AZURE_MONITOR_CONNECTION_STRING=your_connection_string

# Copilot SDK Configuration
# COPILOT_MODEL=gpt-4o
# COPILOT_PROVIDER_BASE_URL=https://your-azure-openai.openai.azure.com
# COPILOT_PROVIDER_API_KEY=your_api_key

# ElevenLabs (voiceover generation)
ELEVEN_API_KEY=your_elevenlabs_api_key
