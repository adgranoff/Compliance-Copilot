{
  "name": "compliance-copilot",
  "version": "1.0.0",
  "description": "AI-powered compliance review for pull requests using GitHub Copilot SDK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "mock:workiq": "tsx mock-services/work-iq/server.ts",
    "mock:fabriciq": "tsx mock-services/fabric-iq/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run mock:workiq\" \"npm run mock:fabriciq\""
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.26",
    "@octokit/rest": "^21.1.1",
    "express": "^4.21.2",
    "dotenv": "^16.4.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.4",
    "vitest": "^3.0.5",
    "eslint": "^9.20.0",
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
