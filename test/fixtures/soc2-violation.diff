+import express from "express";
+
+const app = express();
+
+// Login endpoint with weak password handling
+app.post("/api/login", async (req, res) => {
+  const { username, password } = req.body;
+  const user = await db.query(
+    `SELECT * FROM users WHERE username = '${username}' AND password = '${password}'`
+  );
+  if (user) {
+    // Session never expires
+    res.cookie("session", user.id, { httpOnly: false });
+    res.json({ token: user.id });
+  }
+});
+
+// Admin endpoint with no authorization
+app.delete("/api/admin/users/:id", async (req, res) => {
+  await db.query(`DELETE FROM users WHERE id = ${req.params.id}`);
+  res.json({ deleted: true });
+});
+
+// User input directly rendered
+app.get("/api/profile", (req, res) => {
+  const name = req.query.name;
+  res.send(`<html><body><h1>Welcome ${name}</h1></body></html>`);
+});
+
+// Error handling swallows everything
+app.use((err, req, res, next) => {
+  try {
+    handleError(err);
+  } catch (e) {}
+  res.status(500).json({ error: "Something went wrong" });
+});
+
+app.listen(3000);
